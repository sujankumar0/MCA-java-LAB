package sujan;
interface Vehicle {
    void drive();
    void start();
    void engine();
}

class Car implements Vehicle {
    public void drive() {
        System.out.println("Car runs on 4 wheels");
    }
    public void start() {
		System.out.println("The car starts with key ");
		}
	public void engine() {
		System.out.println("the car engine has multiple strokes");
	}
}
class Motorcycle implements Vehicle {
    public void drive() {
        System.out.println("Motorcycle runs on 2 wheels");
    }
    public void start() {
		 System.out.println("The motorcycle starts with kick");
	 }
	 public void engine() {
		 System.out.println("tht bike engine is single stroke");
	 }
}
public class VehicalDemo {
    public static void main(String[] args) {
        Vehicle v1 = new Car();
        Vehicle v2 = new Motorcycle();
        v1.drive();
        v2.drive();
        v1.start();
        v2.start();
        v1.engine();
        v2.engine();
    }
}
