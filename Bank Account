package sujan;

import java.util.Scanner;

public class BankAccount{
	String name;
	String accountType;
	double balance;
	
	static int totalAccounts=0;
	
	BankAccount(String name){
		this.name=name;
		this.accountType="Savings";
		this.balance=0;
		totalAccounts++;
	}
	BankAccount(String name,double initialDeposit){
		this.name=name;
		this.accountType="Savings";
		this.balance=initialDeposit;
		totalAccounts++;
	}
	BankAccount(String name, double initialDeposit,String accountType){
		this.name=name;
		this.accountType=accountType;
		this.balance=initialDeposit;
		totalAccounts++;
	}
void deposit(double amount) {
		balance += amount;
		System.out.println("Deposited"+amount+"successfully");
	}
	void deposit(double amount,String transactionType) {
		balance += amount;
		System.out.println("Deposited"+amount+ "via"+transactionType+".");
	}
	void withdraw(double amount) {
		if(amount>balance) {
			System.out.println("Insufficent Balance Transaction Failed");
		}
		else 
		{
			balance -=amount;
			System.out.println("Withdrawn"+amount+"successfully");
		}
	}
	void displayAccount() {
		System.out.println("\n-------- Account details-----");
		System.out.println("Name     :"+name);
		System.out.println("Account Type:"+accountType);
		System.out.println("Balance      :"+balance);
	}
	static void showTotalAccounts() {
		System.out.println("\n Total Account Credited:"+totalAccounts);
	}
public static void main(String[]args) {
		
		Scanner sc = new Scanner(System.in);
		
		System.out.println("------Creat New Bank Account------");
		
		System.out.println("Enter name:");
		String name=sc.nextLine();
		
		System.out.println("Enter Initial Deposit:");
        double deposit=sc.nextDouble();
        sc.nextLine();
        
        System.out.println("Enter AccountType(savings/current):");
        String type=sc.nextLine();
        
        BankAccount acc=new BankAccount(name,deposit,type);
  int choice;
        
        do {
        	System.out.println("----Bank Menu----");
        	System.out.println("1. Deposit(simple)");
        	System.out.println("2.Deposit(With transaction type)");
        	System.out.println("3.withdraw  ");
        	System.out.println("4. Account details");
        	System.out.println("5.Show Total Accounts");
        	System.out.println("6.exit");
        	System.out.println("Enter your choice:");
        	choice=sc.nextInt();
switch(choice) {
        	case 1:
        		   System.out.print("Enter amount:");
        		   double amt =sc.nextDouble();
        		   acc.deposit(amt);
        		   break;
        	case 2:
        		System.out.print("Enter amount");
        		double amount=sc.nextDouble();
     		    System.out.print("Enter Deposit type cash/cheque/upi:");
     		    String tx=sc.next ();
     		    acc.deposit(amount,tx);
     		    break;
        	case 3:
        		System.out.print("Enter amount to Withdraw");
        		double w=sc.nextDouble();
        		acc.withdraw(w);
        		break;
        	case 4:
        		acc.displayAccount();
        		break;
        	case 5:
        		BankAccount.showTotalAccounts();
        		break;
        	case 6:
        		System.out.println("Exiting ");
        		break;
        		
        		default :
        			System.out.println("Invalid choice");
        		
        	}
        }while(choice !=6);
        sc.close();
	}
	
}
